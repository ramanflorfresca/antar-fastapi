"""
antar_engine/prompt_builder.py

VOICE: Antar is an AI life navigation system — like Waze, but for your life.
NOT a pandit. NOT a fortune teller. A calm, data-driven navigator.

Every response must make the user feel:
  SEEN → UNDERSTOOD → EMPOWERED → EQUIPPED

Mantras are kept authentic — but non-Indian users also get sound alternatives
from a safe lookup table (no LLM hallucination risk).
"""

from __future__ import annotations
from datetime import datetime


# ── Sound alternatives — safe lookup table, never LLM-generated ───────────────
# Keyed by planet. LLM is told to pick FROM this — never invent alternatives.

SOUND_ALTERNATIVES = {
    "Sun": {
        "mantra":    "Om Suryaya Namaha — 9 times at sunrise facing east",
        "buddhist":  "Tibetan singing bowl in D (solar frequency) — 5 min morning",
